# ──────────────────────────────────────────────────────────────
# Mosaic bridge SHADOW-MODE config — TEMPLATE (no real secrets).
#
# Copy to .env on the target machine and fill in real values.
# Never commit a file containing real API keys.
#
# With BRIDGE_SHADOW_MODE=true, the bridge:
#   • connects to UniFi Access and listens to tap events
#   • resolves each tap against the local store + Redpoint cache
#   • logs every decision ("SHADOW: would unlock ..." / "SHADOW: would record ...")
#   • NEVER calls UniFi door unlock
#   • NEVER calls UniFi user status updates (reactivate/deactivate)
#   • NEVER calls Redpoint createCheckIn
#
# Deploy this as /usr/local/mosaic-bridge/.env on the MacBook, then
# `sudo launchctl kickstart -k system/com.mosaic.bridge`. Switch to the live
# config only after the logs look correct for several days.
# ──────────────────────────────────────────────────────────────

# ── UniFi Access ─────────────────────────────────────────
# Host 127.0.0.1 only if the bridge is on the UDM itself. For an off-box
# MacBook install, set this to the UDM's LAN IP (e.g. 192.168.1.1).
UNIFI_HOST=192.168.1.1
UNIFI_PORT=12445
UNIFI_API_TOKEN=REPLACE_WITH_UNIFI_DEVELOPER_API_TOKEN

# ── Redpoint HQ ──────────────────────────────────────────
REDPOINT_API_URL=https://lefclimbing.rphq.com
REDPOINT_API_KEY=REPLACE_WITH_REDPOINT_API_KEY
REDPOINT_FACILITY_CODE=Mosaic
# Leaving the gate ID populated is still safe — shadow mode skips
# createCheckIn regardless. Keeping it here so the log shows
# "would record check-in in Redpoint (gateId=...)" for verification.
REDPOINT_GATE_ID=REPLACE_WITH_REDPOINT_GATE_ID

# ── Bridge settings ──────────────────────────────────────
BRIDGE_PORT=3500
# Start on loopback. Once the dashboard is verified over an SSH tunnel,
# switch to 0.0.0.0 and set ALLOWED_NETWORKS to the staff subnet.
BIND_ADDR=127.0.0.1
LOG_LEVEL=debug
DATA_DIR=/usr/local/mosaic-bridge/data
UNLOCK_DURATION_MS=5000

# Generate these with: openssl rand -hex 32  (and  openssl rand -hex 16)
# ADMIN_API_KEY protects the admin HTTP API (ingest, members, etc).
# STAFF_PASSWORD is the dashboard login password.
ADMIN_API_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
STAFF_PASSWORD=REPLACE_WITH_STAFF_PASSWORD

# ── Shadow mode ON ───────────────────────────────────────
BRIDGE_SHADOW_MODE=true

# ── Sync settings ────────────────────────────────────────
SYNC_INTERVAL_HOURS=24
SYNC_PRUNE_HOUR=3
SYNC_PAGE_SIZE=100
